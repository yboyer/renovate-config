{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":configMigration",
    "abandonments:recommended",
    "security:minimumReleaseAgeNpm",
    ":disableRateLimiting",
    "group:recommended"
  ],
  "rangeStrategy": "bump",
  "platformAutomerge": false,
  "internalChecksAsSuccess": true,
  "minimumReleaseAge": "3 days",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "minimumReleaseAge": null,
    "commitMessagePrefix": "[SECURITY]",
    "branchTopic": "{{{datasource}}}-{{{depNameSanitized}}}-vulnerability",
    "prCreation": "immediate",
    "enabled": true,
    "labels": [
      "security"
    ],
    "assignees": [
      "yboyer"
    ]
  },
  "packageRules": [
    {
      "description": "Disable GitHub Actions digest PRs",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "enabled": false
    },
    {
      "matchUpdateTypes": [
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "description": "Handle vulnerabilities immediately",
      "matchUpdateTypes": [
        "vulnerability"
      ],
      "minimumReleaseAge": null,
      "prCreation": "immediate"
    }
  ]
}
